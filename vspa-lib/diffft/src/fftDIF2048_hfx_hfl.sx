	st.laddr [a3]+16;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]-15;		ld.normal R1;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]+16;		ld.normal R3;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]-15;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]+16;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]-15;		ld.normal R0;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]+16;		ld.normal R2;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]-15;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]+16;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]-15;		ld.normal R1;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]+16;		ld.normal R3;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]-15;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]+16;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]-15;		ld.normal R0;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]+16;		ld.normal R2;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]-15;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]+16;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;	set.loop 5;
	st.laddr [a3]+1;		ld.normal R1;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]+16;		ld.normal R3;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;									loop_begin;
	ld.laddr [a0]-15;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]+16;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]-15;		ld.normal R0;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]+16;		ld.normal R2;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]-15;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]+16;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]-15;		ld.normal R1;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;									loop_end;
	ld.laddr [a0]+16;		ld.normal R3;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]-15;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]+16;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]-15;		ld.normal R0;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]+16;		ld.normal R2;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]+1;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]+16;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]-15;		ld.normal R1;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]+8;		ld.normal R3;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]-7;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]+16;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;	mv nco_k, 4;
	st.laddr [a3]-15;		ld.normal R0;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]+8;		ld.normal R2;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;								/* stage 2 ends */
	ld.laddr [a0]-7;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;								/* stage 3 begins */
	st.laddr [a3]+16;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]-15;		ld.normal R1;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]+8;		ld.normal R3;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]-7;		 									dif.sau;	wr.fftn;
	st.laddr [a3]+16;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]-15;		ld.normal R0;	rd S0; nco;	rd S2;				wr.fftn;
	ld.laddr [a0]+8;		ld.normal R2;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]-7;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
			 								rd S0; nco;	rd S2;	dif.sau;	wr.fftn;	set.loop 3, 32;
	st.laddr [a3]+16;		ld.normal R1;	rd S0; nco;	rd S2;	dif.sau;
	st.laddr [a3]+1;		ld.normal R3;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
