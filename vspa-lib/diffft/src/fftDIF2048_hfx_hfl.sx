	st.laddr [a3]+1;		ld.normal R0;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]+16;		ld.normal R2;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]-15;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
			 								rd S0; nco;	rd S2;	dif.sau;	wr.fftn;	set.loop 5, 8;
							ld.normal R1;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]+16;		ld.normal R3;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;									loop_begin;
	ld.laddr [a0]-15;		 				rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
