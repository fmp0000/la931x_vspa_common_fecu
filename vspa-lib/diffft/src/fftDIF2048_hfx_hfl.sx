#include "vspa.h"
   .section   .text

// =============================================================================
//! @file           fftDIF2048_hfx_hfl.sx
//! @brief          2048 pt FFT and IFFT functions using DIF   
//! @author         NXP Semiconductors
// =============================================================================

// -----------------------------------------------------------------------------
// Subroutine name: fftDIF2048_hfx_hfl/ifftDIF2048_hfx_hfl
//
// Subroutines called by this subroutine:
//    NONE
//
// ASM implementation description:
//    Data for DIF butterflies is read into VRA. All stages are computed within the VRA 
//      and final output is shipped off to memory.  
//
// Notes:
//    NONE
//
// -----------------------------------------------------------------------------
   .global  _fftDIF2048_hfx_hfl
   .type   _fftDIF2048_hfx_hfl, @function
_fftDIF2048_hfx_hfl:
#ifndef LIB_FFT_STUB
	
	jmp core_fftDIF2048_hfx_hfl;
	set.nco radix2, 1, 2097152;
   	set.range a0, a2, g0;
   	
#else
	rts;
   	nop;
   	nop;
   	
#endif // LIB_FFT_STUB

   .size   _fftDIF2048_hfx_hfl, .-_fftDIF2048_hfx_hfl

//===================================================================================
   .global  _ifftDIF2048_hfx_hfl
   .type   _ifftDIF2048_hfx_hfl, @function
_ifftDIF2048_hfx_hfl:
#ifndef LIB_FFT_STUB

	jmp core_fftDIF2048_hfx_hfl;
   	.quad ((0x0<<60) | (0x04<<54) | (0x2<<52) | (0x1<<36) | (0x1<<34) | (0x200000<<2))
   	set.range a0, a2, g0;
   	
#else
	rts;
   	nop;
   	nop;
   	
#endif // LIB_FFT_STUB

	nop;
   	rts;
   	nop;
   	nop;

   .size   _ifftDIF2048_hfx_hfl, .-_ifftDIF2048_hfx_hfl


// ***************************** CORE FUNCTION *****************************
   .type   core_fftDIF2048_hfx_hfl, @function
core_fftDIF2048_hfx_hfl:
	ld.laddr [a0]+1;																	clr.VRA ;																		
	ld.laddr [a0]+31;																	set.VRAincr rS2, 16;																
	ld.laddr [a0]+1;																	set.VRAincr rS0, 16;
	ld.laddr [a0]-31;		ld.h2l R0;													set.prec half_fixed, single, half_fixed, single, half;
	setA.VRAptr rS0, 128;	ld.l2h_h2l R0;												set.creg 15, 0xB;
							ld.h2l R2;													set.VRArange1 rS2, 0, 112;
							ld.l2h_h2l R2;												set.VRArange1 rS0, 128, 240;																											
	ld.laddr [a0]+32;						rd S0; nco;	rd S2;							set.Smode S0fftn, S2fftn;
	ld.laddr [a0]-31;						rd S0; nco;	rd S2;
	setA.VRAptr rV, 256;					rd S0; nco;	rd S2;	dif.sau;				setB.VRAptr rSt, 4;				
							ld.h2l_l2h R0;	rd S0; nco;	rd S2;	dif.sau;				set.VRArange1 rV, 256, 304;
							ld.h2l_l2h R2;						dif.sau;				set.VRArange2 rV, 384, 432;
	ld.laddr [a0]+32;						rd S0; nco;	rd S2;	dif.sau;				set.VRAincr rV, 16;
	ld.laddr [a0]-31;						rd S0; nco;	rd S2;				wr.fftn;	mvB a3, a1;
											rd S0; nco;	rd S2;	dif.sau;	wr.fftn;	set.range a3, a1, (4096)*UPHW;
							ld.l2h_h2l R0;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;	set.loop 14, 10;
							ld.l2h_h2l R2;						dif.sau;	wr.fftn;	set.VRArange1 rSt, 4, 7;
	ld.laddr [a0]+32;						rd S0; nco;	rd S2;	dif.sau;				set.VRAincr rSt, 1;
	ld.laddr [a0]-31;						rd S0; nco;	rd S2;				wr.fftn;									loop_begin;
	st.laddr [a3]+32;						rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]-31;		ld.h2l_l2h R0;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
							ld.h2l_l2h R2;						dif.sau;	wr.fftn;
	ld.laddr [a0]+32;						rd S0; nco;	rd S2;	dif.sau;
	ld.laddr [a0]-31;						rd S0; nco;	rd S2;				wr.fftn;
	st.laddr [a3]+32;						rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	st.laddr [a3]-31;		ld.l2h_h2l R0;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
							ld.l2h_h2l R2;						dif.sau;	wr.fftn;
	ld.laddr [a0]+32;						rd S0; nco;	rd S2;	dif.sau;												loop_end;
	ld.laddr [a0]-31;						rd S0; nco;	rd S2;				wr.fftn;
											rd S0; nco;	rd S2;	dif.sau;	wr.fftn;	set.range a0, a1, (4096)*UPHW;
	st.laddr [a3]+32;		ld.h2l_l2h R0;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;	mvB a0, a1;
	st.laddr [a3]-31;		ld.h2l_l2h R2;						dif.sau;	wr.fftn;
	ld.laddr [a0]+16;						rd S0; nco;	rd S2;	dif.sau; 
	ld.laddr [a0]-15;						rd S0; nco;	rd S2;			 	wr.fftn;	mv nco_k, 2;
	st.laddr [a3]+32;						rd S0; nco;	rd S2;	dif.sau; 	wr.fftn;
	st.laddr [a3]-31;		ld.normal R0;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;	set.prec half, single, half, single, half;
	ld.laddr [a0]+16;		ld.normal R2;		 				dif.sau;	wr.fftn;
	ld.laddr [a0]-15;			 			rd S0; nco;	rd S2;	dif.sau;												/* stage 2 begins */
	st.laddr [a3]+32;		 				rd S0; nco;	rd S2;		 		wr.fftn;
	st.laddr [a3]-31;		ld.normal R1;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
	ld.laddr [a0]+16;		ld.normal R3;	rd S0; nco;	rd S2;	dif.sau;	wr.fftn;
