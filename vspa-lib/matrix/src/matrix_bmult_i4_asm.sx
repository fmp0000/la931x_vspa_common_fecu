    ld  [a0]+(64)*UPHW;                 rd S0; rd S1; rd S2;    cmad;     wr.hlinecplx;    set.VRAptr rSt,4;                               // V = IN1(LINE7) * W(IN1,OUT0) => R4
    ld  [a0]+(64)*UPHW;                 rd S0; rd S1; rd S2;    cmad;     wr.hlinecplx;    setB.VRAincr rV,HVR;                            // V = IN1(LINE7) * W(IN1,OUT0) => R5          
