    st.laddr [a2]+1;    ld.normal R3;    rd S0; rd S1; rd S2;    cmad;    wr.hlinecplx;                                                             
    st.laddr [a2]+1;    ld.normal R0;    rd S0; rd S1; rd S2;    cmad;    wr.hlinecplx;                                                           
    ld.laddr [a4]+1;    ld.normal R1;    rd S0; rd S1; rd S2;    cmad;    wr.hlinecplx;                                                                              
    ld.laddr [a3]+1;                     rd S0; rd S1; rd S2;    cmad;    wr.hlinecplx;                                                                   
    ld.laddr [a3]+1;                     rd S0; rd S1; rd S2;    cmad;    wr.hlinecplx;    setB.VRAincr rV,VR;                                                     
    ld.laddr [a4]+1;    ld.normal R2;    rd S0; rd S1; rd S2;    cmad;    wr.hlinecplx;    mvB.VRArange1 rV,g5;                                   
    ld.laddr [a3]+1;    ld.normal R0;    rd S0; rd S1; rd S2;    cmad;    wr.hlinecplx;    set.prec half_fixed,single,single,single,half;                               
    ld.laddr [a3]+1;    ld.normal R1;   rd S0; rd S1; rd S2;     cmad;    wr.hlinecplx;    set.Smode S2hlinecplx;                                                
    st.laddr [a2]+1;    ld.normal R3;   rd S0; rd S1; rd S2;     cmad;    wr.hlinecplx;                                                           
    st.laddr [a2]+1;    ld.normal R0;   rd S0; rd S1; rd S2;     cmad;    wr.hlinecplx;                                    loop_end;                                                                                                 
    
    mv a0,0;      rts;
    set.range a0,a0,0;              // Reset modulo addressing for a0 
    set.range a3,a0,0;              // Reset modulo addressing for a3  

_mat_bmult_i4_d1x2xd3_chfx_csp_chfl_asm_end:

// -----------------------------------------------------------------------------
// Subroutine name: mat_bmult_i4_d1x1xd3_chfl_csp_chfl_asm
// -----------------------------------------------------------------------------
    .section .text
    .global _mat_bmult_i4_d1x1xd3_chfl_csp_chfl_asm
    .type _mat_bmult_i4_d1x1xd3_chfl_csp_chfl_asm, @function
    .size _mat_bmult_i4_d1x1xd3_chfl_csp_chfl_asm, _mat_bmult_i4_d1x1xd3_chfl_csp_chfl_asm_end -_mat_bmult_i4_d1x1xd3_chfl_csp_chfl_asm
_mat_bmult_i4_d1x1xd3_chfl_csp_chfl_asm:

    // dim1 = 128 x k
    // dim2 = 1
    // dim3 >= 1
    
    clr.VRA;
    mpy g3,g0,g1;                   // g3 = dim1 * dim3
    sl g2,g0,1;                     // g2 = dim1 * 2 (input stream size, modulo addresing range)
    set.range a0,a0,g2;             // Set modulo addresing for a0 (1st input stream) 
  
    ld.laddr [a1]+1;                                                                       setB.VRAincr rS0,HVR;
    ld.laddr [a0]+1;                                                                       setB.VRAptr  rS1,2*VR;
    ld.laddr [a0]+1;                                                                       setB.VRAincr rS1,QVR;
    ld.laddr [a1]+1;    ld.normal R2;                                                      setB.creg 24, 2;                                // Set order_i = 2 for n = 4 (S1interp2nc)                         
    ld.laddr [a0]+1;    ld.normal R0;                                                      set.prec half,single,single,single,half;
    ld.laddr [a0]+1;    ld.normal R1;    rd S0; rd S1; rd S2;                              set.Smode S0hlinecplx, S1interp2nc, S2zeros;
                        ld.normal R3;    rd S0; rd S1;                                                                  sr g3,g3,7;        // Loop count: g3 = dim1 * dim3 / 128 
                        ld.normal R0;    rd S0; rd S1;           cmad;                                                  setB.loop g3,10;
                        ld.normal R1;    rd S0; rd S1;           cmad;                     setB.VRAptr rS0,0*VR;                             
                                         rd S0; rd S1;           cmad;                     setB.VRAincr rV,HVR;
    ld.laddr [a1]+1;                     rd S0; rd S1;           cmad;                     setB.VRAptr  rV,4*VR;        loop_begin;
    ld.laddr [a0]+1;                     rd S0; rd S1;           cmad;    wr.hlinecplx;                                                          
    ld.laddr [a0]+1;                     rd S0; rd S1;           cmad;    wr.hlinecplx;    setB.VRAptr rS0,0*VR;                                                                                                                                                // V = OUT0(LINE0) => R4 
    ld.laddr [a1]+1;    ld.normal R2;                            cmad;    wr.hlinecplx;    setB.VRAptr rS1,2*VR;                                                        
    ld.laddr [a0]+1;    ld.normal R0;                            cmad;    wr.hlinecplx;    setB.VRAincr rSt,1;                                         
    ld.laddr [a0]+1;    ld.normal R1;    rd S0; rd S1;                    wr.hlinecplx;    setB.VRAptr rSt,4;                                                       
    st.laddr [a2]+1;    ld.normal R3;    rd S0; rd S1;                    wr.hlinecplx;                                                                            
    st.laddr [a2]+1;    ld.normal R0;    rd S0; rd S1;           cmad;    wr.hlinecplx;                                                                      
    st.laddr [a2]+1;    ld.normal R1;    rd S0; rd S1;           cmad;    wr.hlinecplx;    setB.VRAptr rS0,0*VR;                                                     
    st.laddr [a2]+1;                     rd S0; rd S1;           cmad;                                                   loop_end;                                                                                                    

    rts;
    mv a0,0;
    set.range a0,a0,0;              // Reset modulo addressing for a0   

_mat_bmult_i4_d1x1xd3_chfl_csp_chfl_asm_end:

