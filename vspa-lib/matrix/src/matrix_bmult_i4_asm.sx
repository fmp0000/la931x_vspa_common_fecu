// -----------------------------------------------------------------------------
// Subroutine name: mat_bmult_i4_d1x2xd3_chfl_csp_chfl_asm
// -----------------------------------------------------------------------------
    .section .text
    .global _mat_bmult_i4_d1x2xd3_chfl_csp_chfl_asm
    .type _mat_bmult_i4_d1x2xd3_chfl_csp_chfl_asm, @function
