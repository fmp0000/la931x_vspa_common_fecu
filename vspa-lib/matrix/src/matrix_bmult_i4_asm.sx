_mat_bmult_i4_d1x2xd3_chfl_csp_chfl_asm:

    // dim1 = 128 x k
    // dim2 = 2
    // dim3 >= 1
    
    sl g2,g0,1;                                     // g2 = dim1 * 2 (input stream size, modulo addresing range)
    mvB a3,g2;
    mpy g3,g0,g1;                                   // g3 = dim1 * dim3
    add a3,a3,a0;          clr.VRA;
    set.range a0,a0,g2;                             // Set modulo addresing for a0 (1st input stream)
    set.range a3,a3,g2;                             // Set modulo addresing for a3 (2nd input stream)
    mvB a4,g3;             setA.VRAincr rS0,HVR;
    add a4,a4,a1;          setB.VRAptr  rS1,2*VR;   // Pointer for second half of mat: a4 = a1 + dim1 * dim3
    
    set.VRArange1 rS0,0*VR,1*VR+HVR; 
    
    mv g5,((5*VR)*0x10000+4*VR);                    // Wrap & start for {R4,R5} with VR increment (rV and rS2)
    mv g6,((7*VR+HVR)*0x10000+4*VR);                // Wrap & start for {R4,R5,R6,R7} with HVR increment (rV)
    
    ld.laddr [a1]+1;                                                                       setB.VRAincr rS1,QVR;
    ld.laddr [a0]+1;                                                                       setB.VRAptr  rS2,4*VR;
    ld.laddr [a0]+1;                                                                       setB.VRAincr rS2,VR;
    ld.laddr [a1]+1;    ld.normal R2;                                                      setB.creg 24, 2;                                       // Set order_i = 2 for n = 4 (S1interp2nc)                         
    ld.laddr [a0]+1;    ld.normal R0;                                                      set.prec half,single,single,single,single;
    ld.laddr [a0]+1;    ld.normal R1;    rd S0; rd S1; rd S2;                              set.Smode S0hlinecplx, S1interp2nc, S2zeros;
                        ld.normal R3;    rd S0; rd S1; rd S2;                              set.VRArange1 rS1,2*VR,3*VR+3*QVR;                          
                        ld.normal R0;    rd S0; rd S1; rd S2;    cmad;                                                     sr g4,g3,7;            // Loop count: g4 = (dim1 * dim3) / 128
    ld.laddr [a4]+1;    ld.normal R1;    rd S0; rd S1; rd S2;    cmad;                     mvB.VRArange1 rS2,g5;                             
    ld.laddr [a3]+1;                     rd S0; rd S1; rd S2;    cmad;                     setB.VRAptr   rV,4*VR;
    ld.laddr [a3]+1;                     rd S0; rd S1; rd S2;    cmad;                     setB.VRAincr  rV,VR;                           
    ld.laddr [a4]+1;    ld.normal R2;    rd S0; rd S1; rd S2;    cmad;    wr.hlinecplx;    mvB.VRArange1 rV,g5;                                   
    ld.laddr [a3]+1;    ld.normal R0;    rd S0; rd S1; rd S2;    cmad;    wr.hlinecplx;    set.prec half,single,single,single,half;                                                  
    ld.laddr [a3]+1;    ld.normal R1;   rd S0; rd S1; rd S2;     cmad;    wr.hlinecplx;    set.Smode S2hlinecplx;                                
                        ld.normal R3;   rd S0; rd S1; rd S2;     cmad;    wr.hlinecplx;                                    setB.loop g4,16;       
                        ld.normal R0;   rd S0; rd S1; rd S2;     cmad;    wr.hlinecplx;                                                           
    ld.laddr [a1]+1;    ld.normal R1;   rd S0; rd S1; rd S2;     cmad;    wr.hlinecplx;    setB.VRAincr rSt,1;             loop_begin;             
    ld.laddr [a0]+1;                    rd S0; rd S1; rd S2;     cmad;    wr.hlinecplx;    set.VRAptr rSt,4;                                      
    ld.laddr [a0]+1;                    rd S0; rd S1; rd S2;     cmad;    wr.hlinecplx;    setB.VRAincr rV,HVR;                                   
    ld.laddr [a1]+1;    ld.normal R2;   rd S0; rd S1; rd S2;     cmad;    wr.hlinecplx;    mvB.VRArange1 rV,g6;                                   
    ld.laddr [a0]+1;    ld.normal R0;   rd S0; rd S1; rd S2;     cmad;    wr.hlinecplx;    set.prec half,single,single,single,single;             
    ld.laddr [a0]+1;    ld.normal R1;    rd S0; rd S1; rd S2;    cmad;    wr.hlinecplx;    set.Smode S2zeros;                                                        
    st.laddr [a2]+1;    ld.normal R3;    rd S0; rd S1; rd S2;    cmad;    wr.hlinecplx;                                                             
    st.laddr [a2]+1;    ld.normal R0;    rd S0; rd S1; rd S2;    cmad;    wr.hlinecplx;                                                           
    ld.laddr [a4]+1;    ld.normal R1;    rd S0; rd S1; rd S2;    cmad;    wr.hlinecplx;                                                                              
    ld.laddr [a3]+1;                     rd S0; rd S1; rd S2;    cmad;    wr.hlinecplx;                                                                   
    ld.laddr [a3]+1;                     rd S0; rd S1; rd S2;    cmad;    wr.hlinecplx;    setB.VRAincr rV,VR;                                                     
    ld.laddr [a4]+1;    ld.normal R2;    rd S0; rd S1; rd S2;    cmad;    wr.hlinecplx;    mvB.VRArange1 rV,g5;                                   
    ld.laddr [a3]+1;    ld.normal R0;    rd S0; rd S1; rd S2;    cmad;    wr.hlinecplx;    set.prec half,single,single,single,half;                               
    ld.laddr [a3]+1;    ld.normal R1;   rd S0; rd S1; rd S2;     cmad;    wr.hlinecplx;    set.Smode S2hlinecplx;                                                
    st.laddr [a2]+1;    ld.normal R3;   rd S0; rd S1; rd S2;     cmad;    wr.hlinecplx;                                                           
    st.laddr [a2]+1;    ld.normal R0;   rd S0; rd S1; rd S2;     cmad;    wr.hlinecplx;                                    loop_end;                                                                                                 
    
    mv a0,0;      rts;
    set.range a0,a0,0;              // Reset modulo addressing for a0 
    set.range a3,a0,0;              // Reset modulo addressing for a3  

