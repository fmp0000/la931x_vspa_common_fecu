    ld  [a0]+(64)*UPHW; ld.normal R0;   rd S0; rd S1; rd S2;    cmad;    wr.hlinecplx;     set.prec half_fixed,single,single,single,single;// V = OUT0(LINE4) => R4
    ld  [a0]+(gv)*UPHW; ld.normal R1;    rd S0; rd S1; rd S2;   cmad;    wr.hlinecplx;     set.Smode S2zeros;                            // V = OUT0(LINE5) => R5                                    
  st [a2]+(64)*UPHW;    ld.normal R3;    rd S0; rd S1; rd S2;   cmad;    wr.hlinecplx;     set.VRAptr rSt,5;                             // V = OUT0(LINE5) => R5
  st [a2]+(64)*UPHW;    ld.normal R0;    rd S0; rd S1; rd S2;    cmad;   wr.hlinecplx;                              setB.loop g0,8;      // V = OUT0(LINE6) => R6
