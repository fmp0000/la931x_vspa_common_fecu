    ld  [a0]-g2;        ld.normal R1;    rd S0; rd S1; rd S2;   cmad;    wr.hlinecplx;                                                   // V = IN1(LINE1) * W(IN1,OUT0) => R4           
                        ld.normal R3;    rd S0; rd S1; rd S2;   cmad;    wr.hlinecplx;                               sub g1,1;           // V = IN1(LINE1) * W(IN1,OUT0) => R5           
                        ld.normal R0;    rd S0; rd S1; rd S2;    cmad;   wr.hlinecplx;                               cmp g1,0;           // V = IN1(LINE2) * W(IN1,OUT0) => R4
