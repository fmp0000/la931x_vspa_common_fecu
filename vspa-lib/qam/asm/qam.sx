    .global _qamDemod16
    .type   _qamDemod16, @function

_qamDemod16:
    
    mv g3, QAM_NORMALIZATION_16;
    ld.laddr [a0]+1;  setB.VRAptr rV, 128;
    floatx2n g3, g3, 1;
    fill.w [rV], g3;
    ld.laddr [a0]+1;  ld.normal R0; setB.VRAptr rS2, 128; 
                                    rd S0; rd S1; rd S2; set.Smode S0chs, S0abs, S1real1, S2i1r1i1r1;
    st.laddr [a2]+2;
    ld.laddr [a0]+1;  ld.normal R0;        rmad;
    set.loop g4, 3;                 rd S0;
    st.laddr [a2]+2;  setB.VRAptr rV, 0;  
    ld.laddr [a0]+1;  ld.normal R0;        rmad;                loop_begin;
    st.laddr [a2]-3;                rd S0;        wr.straight;
    st.laddr [a2]+5;                                            loop_end;
    add a2, (-192)*UPHW;                   rmad;
    sl g1, g1,1;                                  wr.straight;
    st.laddr [a2]+2;
    set.prec single, half, half, single, half_fixed; 
    jmp _qamLlrPack:
    mv a0, _qamDemodScratch;                      wr.straight;                
    st.laddr [a2]+0;
                                                  
    rts;  
    fnop; 
    fnop;

    .size   _qamDemod16, .-_qamDemod16



    .global _qamDemod64
    .type   _qamDemod64, @function

_qamDemod64:
    

    mv g3, QAM_NORMALIZATION_64;
    ld.laddr [a0]+1;  setB.VRAptr rV, 128;
    floatx2n g3, g3, 2;  //g3=4*Normalization
    fill.w [rV], g3;
    ld.laddr [a0]+1;  ld.normal R0; setB.VRAptr rS2, 128; 
                                    rd S0; rd S1; rd S2; set.Smode S0chs, S0abs, S1real1, S2i1r1i1r1;
    st.laddr [a2]+3;
    ld.laddr [a0]+1;  ld.normal R0;        rmad;
    set.loop g4, 3;                 rd S0;
    st.laddr [a2]+3;  setB.VRAptr rV, 0;  
    ld.laddr [a0]+1;  ld.normal R0;        rmad;                loop_begin;
    st.laddr [a2]-5;                rd S0;        wr.straight;
    st.laddr [a2]+8;                                            loop_end;
    add a2, (-320)*UPHW;                   rmad;
    add a3, (64)*UPHW;                            wr.straight;
    floatx2n g3, g3, -1;
    ld.laddr [a3]+3;
    st.laddr [a2]+3;                              wr.straight;
    st.laddr [a2]+0;
    ld.laddr [a3]+3;  setB.VRAptr rV, 128;
    fill.w [rV], g3;  ld.normal R0;             
    ld.laddr [a3]+3;                rd S0; rd S1; rd S2;  setB.VRAptr rV, 0;
                      ld.normal R0; mv a4, _qamDemodScratch;  
    ld.laddr [a3]+3;                rd S0; rmad; 
    set.loop g4, 2;   ld.normal R0;
    ld.laddr [a3]+3;                rd S0; rmad;
    add a4, (128)*UPHW;ld.normal R0;
    ld.laddr [a3]+3;                rd S0; rmad;  wr.straight;  loop_begin;
    st.laddr [a4]+3;  ld.normal R0;                             loop_end;                                          
    set.prec single, half, half, single, half_fixed; wr.straight;      
    st.laddr [a4]+3;
    mv a0, _qamDemodScratch;                       wr.straight;                                                                             
    jmp _qamLlrPack:
    st.laddr [a4]+3;
    mpyD g1, g1, 3;
                                                 
    rts;  
    fnop; 
    fnop;

    .size   _qamDemod64, .-_qamDemod64



    .global _qamDemod256
    .type   _qamDemod256, @function

_qamDemod256:
    mv g3, QAM_NORMALIZATION_256;
    ld.laddr [a0]+1;  setB.VRAptr rV, 128;
    floatx2n g3, g3, 3;  //g3=8*Normalization
    fill.w [rV], g3;
    ld.laddr [a0]+1;  ld.normal R0; setB.VRAptr rS2, 128; 
                                    rd S0; rd S1; rd S2; set.Smode S0chs, S0abs, S1real1, S2i1r1i1r1;
    st.laddr [a2]+4;
    ld.laddr [a0]+1;  ld.normal R0;        rmad;
    set.loop g4, 3;                 rd S0;
    st.laddr [a2]+4;  setB.VRAptr rV, 0;  
    ld.laddr [a0]+1;  ld.normal R0;        rmad;                loop_begin;
    st.laddr [a2]-7;                rd S0;        wr.straight;
    st.laddr [a2]+11;                                           loop_end;
    add a2, (-448)*UPHW;                   rmad;
    add a3, (64)*UPHW;                            wr.straight;
    floatx2n g3, g3, -1;
    ld.laddr [a3]+4;
    st.laddr [a2]+4;                              wr.straight;
    st.laddr [a2]+0;
    ld.laddr [a3]+4;  setB.VRAptr rV, 128;
    fill.w [rV], g3;  ld.normal R0;             
    ld.laddr [a3]+4;                rd S0; rd S1; rd S2;  setB.VRAptr rV, 0;
                      ld.normal R0; mv a4, _qamDemodScratch;  
    ld.laddr [a3]+4;                rd S0; rmad;  mv a5, a4;
    set.loop g4, 2;   ld.normal R0;
    ld.laddr [a3]+4;                rd S0; rmad;
    add a4, (128)*UPHW;ld.normal R0;
    ld.laddr [a3]+4;                rd S0; rmad;  wr.straight;  loop_begin;
    st.laddr [a4]+4;  ld.normal R0;                             loop_end;                                          
    add a5, (128)*UPHW;                           wr.straight;      
    floatx2n g3, g3, -1;
    st.laddr [a4]+4;                              wr.straight;                                     
    ld.laddr [a5]+4;
    st.laddr [a4]+0;
    ld.laddr [a5]+4;  setB.VRAptr rV, 128;
    fill.w [rV], g3;  ld.normal R0;
    ld.laddr [a5]+4;                rd S0; rd S1; rd S2;  setB.VRAptr rV, 0;
                      ld.normal R0; mv a6, _qamDemodScratch;
    ld.laddr [a5]+4;                rd S0; rmad;               
    set.loop g4, 2;   ld.normal R0;
    ld.laddr [a5]+4;                rd S0; rmad;               
    add a6, (192)*UPHW;ld.normal R0;
    ld.laddr [a5]+4;                rd S0; rmad;  wr.straight;  loop_begin;
    st.laddr [a6]+4;  ld.normal R0;                             loop_end;      
    set.prec single, half, half, single, half_fixed; wr.straight;      
    st.laddr [a6]+4;
    mv a0, _qamDemodScratch;                       wr.straight;        
    jmp _qamLlrPack:
    st.laddr [a6]+0;
    sl g1, g1, 2;

    rts;  
    fnop; 
    fnop;

    .size   _qamDemod256, .-_qamDemod256


    .global _qamDemod1024
    .type   _qamDemod1024, @function

_qamDemod1024:
    mv g3, QAM_NORMALIZATION_1024;
    ld.laddr [a0]+1;  setB.VRAptr rV, 128;
    floatx2n g3, g3, 4;  //g3=16*Normalization
    fill.w [rV], g3;
    ld.laddr [a0]+1;  ld.normal R0; setB.VRAptr rS2, 128; 
                                    rd S0; rd S1; rd S2; set.Smode S0chs, S0abs, S1real1, S2i1r1i1r1;
    st.laddr [a2]+5;
    ld.laddr [a0]+1;  ld.normal R0;        rmad;
    set.loop g4, 3;                 rd S0;
    st.laddr [a2]+5;  setB.VRAptr rV, 0;  
    ld.laddr [a0]+1;  ld.normal R0;        rmad;                loop_begin;
    st.laddr [a2]-9;                rd S0;        wr.straight;
    st.laddr [a2]+14;                                           loop_end;
    add a2, (-576)*UPHW;                   rmad;
    add a3, (64)*UPHW;                            wr.straight;
    floatx2n g3, g3, -1;
    ld.laddr [a3]+5;
    st.laddr [a2]+5;                              wr.straight;
    st.laddr [a2]+0;
    ld.laddr [a3]+5;  setB.VRAptr rV, 128;
    fill.w [rV], g3;  ld.normal R0;             
    ld.laddr [a3]+5;                rd S0; rd S1; rd S2;  setB.VRAptr rV, 0;
                      ld.normal R0; mv a4, _qamDemodScratch;  
    ld.laddr [a3]+5;                rd S0; rmad;  mv a2, a4;
    set.loop g4, 2;   ld.normal R0;
    ld.laddr [a3]+5;                rd S0; rmad;
    add a4, (128)*UPHW;ld.normal R0;
    ld.laddr [a3]+5;                rd S0; rmad;  wr.straight;  loop_begin;
    st.laddr [a4]+5;  ld.normal R0;                             loop_end;                                          
    add a2, (128)*UPHW;                           wr.straight;      
    floatx2n g3, g3, -1;
    st.laddr [a4]+5;                              wr.straight;                                     
    ld.laddr [a2]+5;
    st.laddr [a4]+0;
    ld.laddr [a2]+5;  setB.VRAptr rV, 128;
    fill.w [rV], g3;  ld.normal R0;             
    ld.laddr [a2]+5;                rd S0; rd S1; rd S2;  setB.VRAptr rV, 0;
                      ld.normal R0; mv a6, _qamDemodScratch;  
    ld.laddr [a2]+5;                rd S0; rmad;  mv a7, a6;
    set.loop g4, 2;   ld.normal R0;
    ld.laddr [a2]+5;                rd S0; rmad;
    add a6, (192)*UPHW;ld.normal R0;
    ld.laddr [a2]+5;                rd S0; rmad;  wr.straight;  loop_begin;
    st.laddr [a6]+5;  ld.normal R0;                             loop_end;                                          
    add a7, (192)*UPHW;                           wr.straight;      
    floatx2n g3, g3, -1;
    st.laddr [a6]+5;                              wr.straight;                                     
    ld.laddr [a7]+5;
    st.laddr [a6]+0;
    ld.laddr [a7]+5;  setB.VRAptr rV, 128;    
    fill.w [rV], g3;  ld.normal R0;
    ld.laddr [a7]+5;                rd S0; rd S1; rd S2;  setB.VRAptr rV, 0;
                      ld.normal R0; mv a8, _qamDemodScratch;
    ld.laddr [a7]+5;                rd S0; rmad;               
    set.loop g4, 2;   ld.normal R0;
    ld.laddr [a7]+5;                rd S0; rmad;               
    add a8, (256)*UPHW;ld.normal R0;
    ld.laddr [a7]+5;                rd S0; rmad;  wr.straight;  loop_begin;
    st.laddr [a8]+5;  ld.normal R0;                             loop_end;      
    set.prec single, half, half, single, half_fixed; wr.straight;      
    st.laddr [a8]+5;
    mv a0, _qamDemodScratch;                       wr.straight;        
    jmp _qamLlrPack:
    st.laddr [a8]+0;
    mpyD g1, g1, 5;

    rts;  
    fnop; 
    fnop;

    .size   _qamDemod1024, .-_qamDemod1024

    
    .global _qamLlrPack
    .type   _qamLlrPack, @function

_qamLlrPack:
   
    clr.VRA;
    ld.laddr [a0]+1;  setB.VRAptr rV, 128;
    floatx2n g5,g0,-4;   //g5=snr/16                
    ld.laddr [a0]+1;  setB.VRAptr rS0, 128; 
    mv.w [rV], g5;    ld.normal R0;
    ld.laddr [a0]+1;                  rd S0; rd S1; rd S2;   set.Smode S0hword, S1straight, S2zeros;
    mv a3, (32)*UPHW; ld.normal R0;
    ld.laddr [a0]+1;                  rd S1;  rmad; setB.VRAptr rSt, 2;
    set.loop g1, 2;   ld.normal R0;
    ld.laddr [a0]+1;                  rd S1;  rmad;
                      ld.normal R0;               
    ld.laddr [a0]+1;                  rd S1;  rmad; wr.straight; loop_begin;
    st.llr8  [a1]+a3; ld.normal R0;                              loop_end; 
    
    rts;  
    fnop; 
    fnop;

    .size   _qamLlrPack, .-_qamLlrPack
